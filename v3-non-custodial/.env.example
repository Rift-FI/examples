# Sandbox project API key. Get one from the Rift dashboard:
#   https://dashboard.riftfi.com → New project → sandbox flavour
#
# The widget + backend URL are baked into rift-react@0.3.0 via
# environment="sandbox", so this is the only required var.
VITE_RIFT_API_KEY=

# OPTIONAL — local widget override.
#
# Until widget.sandbox.riftfi.com is deployed on Caprover, you can run
# the sandbox widget locally to test end-to-end:
#
#   git clone git@github.com:Rift-FI/sandbox-widget.git
#   cd sandbox-widget
#   echo "VITE_API_BASE_URL=https://sandbox.riftfi.com"      > .env
#   echo "VITE_DEFAULT_NON_CUSTODIAL=true"                  >> .env
#   echo "VITE_PASSKEY_RP_ID=localhost"                     >> .env
#   echo "VITE_PASSKEY_RP_NAME=Rift Sandbox"                >> .env
#   npm install && npm run dev
#
# Then in this example's .env:
# VITE_WIDGET_URL=http://localhost:6001
